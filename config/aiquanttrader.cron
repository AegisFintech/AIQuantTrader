# AIQuantTrader cron - install with: sudo cp config/aiquanttrader.cron /etc/cron.d/aiquanttrader && sudo chmod 644 /etc/cron.d/aiquanttrader
# Uninstall with: sudo rm /etc/cron.d/aiquanttrader
# Inspect with: cat /etc/cron.d/aiquanttrader && tail -20 /root/AIQuantTrader/logs/cron.log
# All jobs run as root. Stdout/stderr go to /root/AIQuantTrader/logs/cron.log (rotated by the existing logrotate policy).
# Cadence note: stock cron has minute-level scheduling, so price snapshots run every minute without sleep-based duplicate jobs.

# Every minute: ingest Common Files, then capture bid/ask under one DuckDB lock.
* * * * * root cd /root/AIQuantTrader && /usr/bin/flock -n /tmp/aiquanttrader-duckdb.lock .venv/bin/python scripts/mt5_minute_cycle.py >> /root/AIQuantTrader/logs/cron.log 2>&1

# Every 5 minutes: export metrics with evaluated alerts.
*/5 * * * * root cd /root/AIQuantTrader && /usr/bin/flock -w 50 /tmp/aiquanttrader-duckdb.lock .venv/bin/python scripts/mt5_metrics_export.py --json >> /root/AIQuantTrader/logs/cron.log 2>&1

# One minute later: deliver alert transitions when Telegram credentials exist.
1-56/5 * * * * root cd /root/AIQuantTrader && .venv/bin/python scripts/alert_delivery.py >> /root/AIQuantTrader/logs/cron.log 2>&1

# Two minutes later: run the broader host/research/process healthcheck.
2-57/5 * * * * root cd /root/AIQuantTrader && .venv/bin/python scripts/healthcheck.py >> /root/AIQuantTrader/logs/cron.log 2>&1

# Hourly: validate the warehouse
0 * * * * root cd /root/AIQuantTrader && /usr/bin/flock -w 50 /tmp/aiquanttrader-duckdb.lock .venv/bin/python scripts/mt5_validate_warehouse.py >> /root/AIQuantTrader/logs/cron.log 2>&1

# Daily 23:55: archive Common Files to state/mt5/archive/
55 23 * * * root cd /root/AIQuantTrader && .venv/bin/python scripts/archive_common_files.py >> /root/AIQuantTrader/logs/cron.log 2>&1
