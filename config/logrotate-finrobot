# Logrotate policy for FinRobot.
#
# Drops into /etc/logrotate.d/finrobot via:
#   sudo cp config/logrotate-finrobot /etc/logrotate.d/finrobot
# Or use scripts/install_logrotate.sh which does the same with sanity checks.
#
# PM2's out_file / error_file is a single append-only log. We rotate it daily,
# keep 14 days, and run a `pm2 reloadLogs` after so PM2 keeps writing to a
# fresh file under the same path.

/root/FinRobot/logs/combined.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    copytruncate
    create 0640 root root
    sharedscripts
    postrotate
        # Tell PM2 to reopen its log file handles so it stops writing to the
        # rotated-out file. `reloadLogs` is the modern equivalent of the
        # removed `reopenLogs` command.
        pm2 reloadLogs >/dev/null 2>&1 || true
    endscript
}

/root/FinRobot/logs/cron.log /root/FinRobot/logs/alerts.log {
    daily
    rotate 14
    missingok
    notifempty
    compress
    delaycompress
    copytruncate
    create 0640 root root
}
