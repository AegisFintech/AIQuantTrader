# ============================================
# FinRobot Configuration
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control!

# -------------------------------------------
# Data Providers
# -------------------------------------------
CP=

# -------------------------------------------
# LLM (optional - for opencode feedback)
# -------------------------------------------
NV=
NVIDIA_MODEL=qwen/qwen3-235b-a22b

# -------------------------------------------
# Market Defaults
# -------------------------------------------
OKX_SYMBOL=XAU/USD
OKX_BAR=5m

# -------------------------------------------
# MetaTrader 5 (optional - Daemon 1 XAUUSD)
# -------------------------------------------
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=

# -------------------------------------------
# cTrader (optional - alternative executor)
# -------------------------------------------
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_ACCESS_TOKEN=
CTRADER_ACCOUNT_ID=

# -------------------------------------------
# Hyperliquid - Moonshot Daemon (Daemon 2)
# -------------------------------------------
# TRADING_MODE: "paper" (default) or "live"
# WARNING: "live" uses REAL funds. Start with paper!
TRADING_MODE=paper

# Your wallet private key (0x...) - REQUIRED for live trading
# Use a DEDICATED trading wallet, not your main wallet!
HYPERLIQUID_PRIVATE_KEY=

# Your wallet address (0x...) - REQUIRED for live trading
HYPERLIQUID_WALLET_ADDRESS=

# Network: "mainnet" or "testnet" (testnet uses testnet funds)
HYPERLIQUID_NETWORK=mainnet

# API URL (override only if using custom endpoint)
# HYPERLIQUID_API_URL=https://api.hyperliquid.xyz

# -------------------------------------------
# Live Trading Risk Limits (only used in live mode)
# -------------------------------------------
# Maximum position size in USD
LIVE_MAX_POSITION_USD=50

# Maximum leverage (overrides daemon default if set)
# LIVE_MAX_LEVERAGE=3

# Daily loss limit as percentage of balance (e.g. 2 = 2%)
# LIVE_DAILY_LOSS_LIMIT=2
