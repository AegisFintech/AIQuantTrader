# AIQuantTrader active runtime: MT5 demo XAUUSD only.

# MetaTrader 5 demo login
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_MODE=demo
MT5_AUTOTRADING_ENABLED=true

# Optional repo-local runtime overrides. Defaults are usually best.
AIQUANTTRADER_RUNTIME_DIR=
AIQUANTTRADER_WINEPREFIX=
AIQUANTTRADER_MT5_DIR=

# Experimental arm64 MT5 path: Box64 + x86_64 Wine.
AIQUANTTRADER_ALLOW_EMULATED_MT5=false
AIQUANTTRADER_WINE_CMD=
AIQUANTTRADER_X86_WINE_HOME=
AIQUANTTRADER_WINEBOOT_TIMEOUT=60s
AIQUANTTRADER_MT5_INSTALL_TIMEOUT=10m
AIQUANTTRADER_CONFIGURE_PROFILE_ON_START=true
AIQUANTTRADER_ATTACH_SYMBOL=XAUUSD
AIQUANTTRADER_ATTACH_PERIOD=M1
AIQUANTTRADER_ATTACH_PERIOD_TYPE=0
AIQUANTTRADER_ATTACH_PERIOD_SIZE=1
AIQUANTTRADER_SINGLE_CHART_PROFILE=true
AIQUANTTRADER_STARTUP_OPEN_CHART=false

# Autonomous review / Opencode
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENCODE_REVIEW_MODEL=openai/gpt-5.5
AUTOREVIEW_WINDOW_HOURS=6
AUTOREVIEW_INTERVAL_HOURS=6
AUTOREVIEW_MIN_TRADES=12
AUTOREVIEW_HARVEST_FIRST=true
AUTOREVIEW_PROFILE_LAB_MAX_BARS=50000
AUTOREVIEW_PROFILE_LAB_TIMEOUT=1800
AUTOREVIEW_PROFILE_LAB_NICE_LEVEL=10
AUTOREVIEW_ENABLE_PROMOTION_DEPLOY=false
# Safety toggle: when not 'true/1/yes/on', aiquanttrader-review only analyzes; it will not let the LLM edit repo files.
AUTOREVIEW_ENABLE_LLM=false

# Dashboard
DASHBOARD_AUTO_REFRESH=false
DASHBOARD_REFRESH_SECONDS=15

# Telegram warning/critical alert delivery
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALERT_CHAT_ID=

# T3N / Terminal 3 (identity + confidential computing network)
# The API key is a 256-bit hex bearer secret. The DID is a W3C DID (public).
# Keep T3N_API_KEY out of version control. See docs/SECRETS_ROTATION.md.
T3N_API_KEY=
T3N_DID=
