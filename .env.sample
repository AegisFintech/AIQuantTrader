# FinRobot active runtime: MT5 demo XAUUSD/BTCUSD only.

# MetaTrader 5 demo login
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_MODE=demo
MT5_AUTOTRADING_ENABLED=true

# Optional repo-local runtime overrides. Defaults are usually best.
FINROBOT_RUNTIME_DIR=
FINROBOT_WINEPREFIX=
FINROBOT_MT5_DIR=

# Experimental arm64 MT5 path: Box64 + x86_64 Wine.
FINROBOT_ALLOW_EMULATED_MT5=false
FINROBOT_WINE_CMD=
FINROBOT_X86_WINE_HOME=
FINROBOT_WINEBOOT_TIMEOUT=60s
FINROBOT_MT5_INSTALL_TIMEOUT=10m
FINROBOT_CONFIGURE_PROFILE_ON_START=true
FINROBOT_ATTACH_SYMBOL=BTCUSD
FINROBOT_ATTACH_PERIOD=M1
FINROBOT_ATTACH_PERIOD_TYPE=0
FINROBOT_ATTACH_PERIOD_SIZE=1
FINROBOT_SINGLE_CHART_PROFILE=true
FINROBOT_STARTUP_OPEN_CHART=false

# Autonomous review / Opencode
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENCODE_REVIEW_MODEL=openai/gpt-5.5
AUTOREVIEW_WINDOW_HOURS=6
AUTOREVIEW_INTERVAL_HOURS=6
AUTOREVIEW_MIN_TRADES=12
# Safety toggle: when not 'true/1/yes/on', autonomous-review only analyzes; it will not let the LLM edit repo files.
AUTOREVIEW_ENABLE_LLM=false

# Dashboard
DASHBOARD_AUTO_REFRESH=false
DASHBOARD_REFRESH_SECONDS=15

# T3N / Terminal 3 (identity + confidential computing network)
# The API key is a 256-bit hex bearer secret. The DID is a W3C DID (public).
# Keep T3N_API_KEY out of version control. See docs/SECRETS_ROTATION.md.
T3N_API_KEY=
T3N_DID=
